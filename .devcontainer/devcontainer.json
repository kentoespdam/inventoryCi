{
    "name": "InvCI 4.6 (CodeIgniter 4.1.8)",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/var/www/html",
    "forwardPorts": [8080, 3306],
    "portsAttributes": {
        "8080": {
            "label": "CodeIgniter App",
            "onAutoForward": "notify"
        },
        "3306": {
            "label": "MySQL",
            "onAutoForward": "silent"
        }
    },
    "postCreateCommand": "composer install --no-interaction --prefer-dist && ([ -f .env ] || cp env .env)",
    "postStartCommand": "bash .devcontainer/start-server.sh",
    "remoteUser": "www-data",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug",
                "neilbrayfield.php-docblocker",
                "mehedidracula.php-namespace-resolver",
                "recca0120.vscode-phpunit",
                "mtxr.sqltools",
                "mtxr.sqltools-driver-mysql",
                "editorconfig.editorconfig"
            ],
            "settings": {
                "php.validate.executablePath": "/usr/local/bin/php",
                "intelephense.environment.phpVersion": "8.0.0",
                "[php]": {
                    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
                    "editor.tabSize": 4
                }
            }
        }
    }
}
